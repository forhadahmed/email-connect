{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@email-connect/core": ["packages/core/src/index.ts"],
      "@email-connect/core/server": ["packages/core/src/server/index.ts"],
      "@email-connect/gmail": ["packages/gmail/src/index.ts"],
      "@email-connect/graph": ["packages/graph/src/index.ts"]
    },
    "outDir": "dist",
    "rootDir": "."
  },
  "include": ["src/**/*.ts", "packages/**/*.ts", "test/**/*.ts", "examples/**/*.ts", "vitest.config.ts"]
}
